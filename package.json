{
  "name": "daggerquest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "spritesheets": "tsx scripts/makeSpritesheets.ts",
    "manifest": "tsx scripts/makeManifest.ts",
    "upload-assets": "tsx scripts/uploadAssets.ts",
    "anchors": "tsx scripts/patchAnchors.ts",
    "detect-fireframe": "tsx scripts/detectFireFrame.ts",
    "test": "cd playwright && npx playwright test",
    "test:headed": "cd playwright && npx playwright test --headed",
    "test:debug": "cd playwright && npx playwright test --debug",
    "test:ui": "cd playwright && npx playwright test --ui",
    "test:report": "cd playwright && npx playwright show-report",
    "test:install": "cd playwright && npm install && npx playwright install"
  },
  "dependencies": {
    "@dr.pogodin/react-helmet": "^3.1.0",
    "@formspree/react": "^3.0.0",
    "firebase": "^12.10.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.3",
    "pixi.js": "^8.17.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
