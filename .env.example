# Environment Variables
# Copy this file to .env and fill in the values.

# ── Vite (Client-side) ───────────────────────────────────────────────────
# Base URL for loading game assets (spritesheets, etc.)
VITE_ASSET_BASE_URL=

# ── Scripts (Server-side / CI) ───────────────────────────────────────────
# Cloudflare R2 credentials for asset uploads (scripts/uploadAssets.ts)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Cloud Functions ──────────────────────────────────────────────────────
# Set in Google Cloud Secrets Manager, not here.
# RESEND_API_KEY=
